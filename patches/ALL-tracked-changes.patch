 #ifdef USE_OPENSSL3_LIBCTX
+static void sc_openssl3_set_provider_search_path(sc_context_t *ctx)
+{
+#if defined(HAVE_DLFCN_H)
+	Dl_info info;
+	char *libcrypto_path = NULL;
+	char *libcrypto_dir = NULL;
+	char *modules_dir = NULL;
+	size_t modules_dir_len = 0;
+	int rv = 0;
+
+	if (ctx == NULL || ctx->ossl3ctx == NULL || ctx->ossl3ctx->libctx == NULL)
+		return;
+
+	if (!dladdr((void *) OpenSSL_version_num, &info) || info.dli_fname == NULL)
+		return;
+
+	libcrypto_path = strdup(info.dli_fname);
+	if (libcrypto_path == NULL)
+		return;
+
+	libcrypto_dir = dirname(libcrypto_path);
+	if (libcrypto_dir == NULL || *libcrypto_dir == '\0') {
+		free(libcrypto_path);
+		return;
+	}
+
+	modules_dir_len = strlen(libcrypto_dir) + strlen("/ossl-modules") + 1;
+	modules_dir = calloc(1, modules_dir_len);
+	if (modules_dir == NULL) {
+		free(libcrypto_path);
+		return;
+	}
+	snprintf(modules_dir, modules_dir_len, "%s/ossl-modules", libcrypto_dir);
+
+	rv = OSSL_PROVIDER_set_default_search_path(ctx->ossl3ctx->libctx, modules_dir);
+	if (rv == 1)
+		sc_log(ctx, "OpenSSL provider search path set to %s", modules_dir);
+	else
+		sc_log(ctx, "Failed to set OpenSSL provider search path to %s", modules_dir);
+
+	free(modules_dir);
+	free(libcrypto_path);
+#else
+	(void) ctx;
+#endif
+}
+
 static int sc_openssl3_init(sc_context_t *ctx)
 {
 	ctx->ossl3ctx = calloc(1, sizeof(ossl3ctx_t));
