@@ -856,6 +909,7 @@ static int sc_openssl3_init(sc_context_t *ctx)
 						       "legacy");
 	if (ctx->ossl3ctx->legacyprov == NULL) {
 		sc_log(ctx, "Failed to load OpenSSL Legacy provider");
+		sc_log(ctx, "Legacy algorithms may fall back to process-global OpenSSL context");
 	}
